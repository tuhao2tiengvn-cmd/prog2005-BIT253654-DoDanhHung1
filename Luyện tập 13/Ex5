class Flower:
    def __init__(self, color):
        self.__color = color

    # getter
    def get_color(self):
        return self.__color

    # setter
    def set_color(self, color):
        self.__color = color


hoa = Flower("Trắng")

print("Màu ban đầu:", hoa.get_color())

hoa.set_color("Xanh")

print("Màu sau khi đổi:", hoa.get_color())
